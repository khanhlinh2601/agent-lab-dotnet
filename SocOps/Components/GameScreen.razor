@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-50">
    <!-- Header with Gradient -->
    <header class="bg-gradient-primary text-white p-4 shadow-lg">
        <div class="flex items-center justify-between max-w-lg mx-auto">
            <button
                @onclick="OnReset"
                class="text-white text-sm px-3 py-1.5 rounded hover:bg-white hover:bg-opacity-20 transition-colors">
                ← Back
            </button>
            <h1 class="font-heading text-xl font-bold">Soc Ops</h1>
            <div class="w-16"></div>
        </div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-gray-600 text-sm py-3 px-4 font-heading">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo Indicator Banner -->
    @if (HasBingo)
    {
        <div class="bg-gradient-accent text-white text-center py-3 font-heading text-sm animate-slide-down">
            🎉 BINGO! You got a line! 🎉
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-4">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
