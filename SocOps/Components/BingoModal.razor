<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50 animate-fade-in">
    <div class="bg-gradient-primary rounded-2xl p-8 max-w-xs w-full text-center shadow-xl animate-modal-enter relative overflow-hidden">
        <!-- Confetti Elements -->
        <div class="absolute top-4 left-2 text-2xl" style="--tx: 30px; --ty: -100px;">🎊</div>
        <div class="absolute top-8 right-4 text-2xl" style="--tx: -50px; --ty: -80px;">✨</div>
        <div class="absolute top-6 left-1/3 text-2xl" style="--tx: 40px; --ty: -120px;">🎉</div>
        <div class="absolute -bottom-10 -left-10 text-4xl opacity-20">⭐</div>
        <div class="absolute -bottom-5 -right-5 text-4xl opacity-20">🌟</div>

        <!-- Content -->
        <div class="relative z-10">
            <div class="text-6xl mb-4 animate-bounce">🎉</div>
            <h2 class="text-4xl font-bold text-white mb-3" style="text-shadow: 0 3px 10px rgba(0, 0, 0, 0.2);">BINGO!</h2>
            <p class="text-white text-lg mb-8 opacity-95">You completed a line!</p>

            <button
                @onclick="OnDismiss"
                class="btn-secondary w-full">
                Keep Playing
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
