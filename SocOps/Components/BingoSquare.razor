@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-1 right-1 text-white text-lg font-bold animate-square-reveal">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-2 text-center rounded-lg transition-all duration-300 select-none min-h-[60px] text-xs leading-tight font-heading hover:scale-105";

        if (Square.IsFreeSpace)
        {
            return $"{baseClasses} bg-primary text-white font-bold text-sm cursor-default";
        }

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-winning text-white shadow-glow-success animate-winning-glow"
                : "bg-mint text-gray-900 border shadow-lg border-gray-300"
            : "bg-white text-gray-900 border shadow-sm border-soft hover:bg-gray-50 hover:shadow-md";

        return $"{baseClasses} {stateClasses}";
    }
}

